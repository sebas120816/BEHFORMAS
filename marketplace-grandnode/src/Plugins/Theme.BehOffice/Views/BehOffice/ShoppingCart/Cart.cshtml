@inject IPageHeadBuilder pagebuilder
@model ShoppingCartModel
@{
    Layout = "_SingleColumn";

    //title
    pagebuilder.AddTitleParts(Loc["Title.ShoppingCart"]);
}
<div class="page shopping-cart-page">
    <nav class="beh-checkout-progress" aria-label="Proceso de compra">
        <span class="is-active"><b>1</b> Carrito</span>
        <span><b>2</b> Datos y entrega</span>
        <span><b>3</b> Confirmación</span>
    </nav>
    <header class="beh-cart-heading">
        <span>Compra segura BEH</span>
        <h1>Revisa tu pedido</h1>
        <p>Confirma referencias y cantidades. Antes del despacho validaremos contigo cobertura, entrega, ensamble e instalación.</p>
    </header>
    <div class="page-body">
        <partial name="Partials/CartSummary" model="Model"/>
    </div>
    <section class="beh-cart-promises" aria-label="Compromisos de compra">
        <div><span>01</span><strong>Sin sorpresas logísticas</strong><small>Confirmamos transporte, acceso y montaje antes del despacho.</small></div>
        <div><span>02</span><strong>Atención humana</strong><small>Tu pedido queda acompañado por el equipo comercial BEH.</small></div>
        <div><span>03</span><strong>Soporte posventa</strong><small>Garantía y fabricación atendidas por el mismo equipo.</small></div>
    </section>
    <aside class="beh-cart-support" aria-label="Asistencia para el pedido">
        <div><strong>¿Compra para empresa?</strong><span>Solicita precio por volumen y coordinación por etapas.</span></div>
        <div><strong>¿Necesitas instalación?</strong><span>Validamos ciudad, acceso, montaje y tiempos antes del pago.</span></div>
        <a href="https://wa.me/573103200976?text=Hola%20BEH,%20necesito%20ayuda%20con%20mi%20carrito" target="_blank" rel="noopener">Hablar con un asesor</a>
    </aside>
</div>
